<!-- ═══ P6: 홈 위젯 4×2 (#40) ═══ -->
<receiver
    android:name=".CheonhongWidgetCalendar"
    android:exported="true">
    <intent-filter>
        <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
    </intent-filter>
    <meta-data
        android:name="android.appwidget.provider"
        android:resource="@xml/widget_info_calendar" />
</receiver>

<!-- ═══ P6: 홈 위젯 2×2 (#41) ═══ -->
<receiver
    android:name=".CheonhongWidget2x2"
    android:exported="true">
    <intent-filter>
        <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
    </intent-filter>
    <meta-data
        android:name="android.appwidget.provider"
        android:resource="@xml/widget_info_2x2" />
</receiver>

